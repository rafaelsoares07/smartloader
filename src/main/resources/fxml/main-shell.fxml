<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Navigation shell (sidebar + topbar). Owned by the app package (orchestrates the features).
    All colors come from theme.css via styleClass — no hardcoded colors here.
    center is swapped at runtime by MainShellController.
-->

<BorderPane fx:id="rootPane" styleClass="root-pane" stylesheets="@../css/theme.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gertec.smartloader.app.MainShellController">

    <!-- ===== LEFT: fixed sidebar (~210px), dark navy ===== -->
    <left>
        <VBox maxWidth="210" minWidth="210" prefWidth="210" styleClass="sidebar">

            <!-- Brand -->
            <VBox styleClass="brand">
                <Label styleClass="brand-title" text="SMARTLOADER" />
                <HBox alignment="CENTER_LEFT" styleClass="brand-status">
                    <Region styleClass="status-dot, status-online" />
                    <Label styleClass="brand-subtitle" text="v1.0.0 — Gertec" />
                </HBox>
            </VBox>

            <!-- Section: Geral -->
            <Label styleClass="section-title" text="Geral" />
            <Button fx:id="dashboardButton" maxWidth="Infinity" onAction="#showDashboard" styleClass="nav-item" text="Dashboard" />

            <!-- Section: Operação -->
            <Label styleClass="section-title" text="Operação" />
            <Button fx:id="catalogButton" maxWidth="Infinity" onAction="#showCatalog" styleClass="nav-item" text="Smart Databe" />
            <Button fx:id="profileButton" maxWidth="Infinity" onAction="#showProfile" styleClass="nav-item" text="Smart Package" />
            <Button fx:id="recordingButton" maxWidth="Infinity" onAction="#showRecording" styleClass="nav-item" text="Smart Hub" />

            <!-- Section: Sistema -->
            <Label styleClass="section-title" text="Sistema" />
            <Button fx:id="installerButton" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity" onAction="#showInstaller" styleClass="nav-item" text="Instalador" textFill="#e10707">
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
            <font>
               <Font name="Droid Sans Fallback" size="29.0" />
            </font></Button>

            <!-- Spacer pushes the status footer to the bottom -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Footer: connectivity indicators.
                 STATIC PLACEHOLDERS for now — NOT real readings.
                 TODO (future increment): bind dots/labels to real GEDI API / ADB / USB status. -->
            <VBox styleClass="status-footer">
                <HBox alignment="CENTER_LEFT" styleClass="status-row">
                    <Region styleClass="status-dot, status-unknown" />
                    <Label styleClass="status-label" text="GEDI API" />
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="status-row">
                    <Region styleClass="status-dot, status-unknown" />
                    <Label styleClass="status-label" text="ADB" />
                </HBox>
                <HBox alignment="CENTER_LEFT" styleClass="status-row">
                    <Region styleClass="status-dot, status-unknown" />
                    <Label styleClass="status-label" text="Terminais USB" />
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ===== TOP: topbar (~64px), light ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets bottom="0" left="20" right="20" top="0" />
            </padding>

            <!-- Left: breadcrumb -->
            <Label fx:id="breadcrumbLabel" styleClass="breadcrumb" text="HOME / Dashboard" />

            <Region HBox.hgrow="ALWAYS" />

            <!-- Center: Gertec logo.
                 TODO: place the real PNG at resources/images/gertec-logo.png and enable the
                 ImageView below. While the asset is absent we show a text placeholder. -->
            
            <ImageView fitHeight="42" preserveRatio="true">
                <image>
                    <Image url="@../images/gertec-logo.png" />
                </image>
            </ImageView>
        

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right: actions -->
            <HBox alignment="CENTER_RIGHT" styleClass="topbar-actions">
                <Button styleClass="secondary" text="Sincronizar Cache" />
                <Button styleClass="primary" text="Novo GPK" />
            </HBox>
        </HBox>
    </top>

    <!-- ===== CENTER: content area, swapped by navigation (starts on Dashboard) ===== -->
    <center>
        <StackPane prefHeight="480.0" prefWidth="1384.0" styleClass="content-area" />
    </center>
</BorderPane>
