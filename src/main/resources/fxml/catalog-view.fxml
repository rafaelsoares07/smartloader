<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.TreeTableColumn?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Smart Database view: cada repositório é um TitledPane recolhível.
    Padrão de interação (uniforme em todas as seções):
        - ADICIONAR e EDITAR abrem um DIÁLOGO (pop-up) — o formulário não fica no card.
        - EDITAR / EXCLUIR só ficam habilitados quando há uma linha selecionada.
        - Selecionar uma linha NÃO preenche nada na tela (sem efeito colateral).
    A ORDEM DE CRIAÇÃO (de cima para baixo) é mantida:
        1) Criar ODM  2) Criar terminais dessa ODM  3) Criar assinatura e vinculá-la (1:1) à ODM
    O card de APKs é independente e fica ao final.
    Todas as cores vivem em theme.css (apenas styleClass aqui, nunca cor hardcoded).
-->
<ScrollPane fitToWidth="true" styleClass="catalog-scroll"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gertec.smartloader.smartdatabase.ui.CatalogViewController">

    <VBox styleClass="catalog-root" spacing="14">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>


        <HBox spacing="16" styleClass="summary-bar">
            <VBox styleClass="summary-card">
                <Label text="APKs" styleClass="summary-card-title"/>
                <Label fx:id="apkCountLabel" text="0" styleClass="summary-card-value"/>
            </VBox>
            <VBox styleClass="summary-card">
                <Label text="Terminais" styleClass="summary-card-title"/>
                <Label fx:id="terminalCountLabel" text="0" styleClass="summary-card-value"/>
            </VBox>
            <VBox styleClass="summary-card">
                <Label text="ODMs" styleClass="summary-card-title"/>
                <Label fx:id="odmCountLabel" text="0" styleClass="summary-card-value"/>
            </VBox>
            <VBox styleClass="summary-card">
                <Label text="Assinaturas" styleClass="summary-card-title"/>
                <Label fx:id="signingCountLabel" text="0" styleClass="summary-card-value"/>
            </VBox>
            <VBox styleClass="summary-card">
                <Label text="Clientes" styleClass="summary-card-title"/>
                <Label fx:id="clientCountLabel" text="0" styleClass="summary-card-value"/>
            </VBox>
        </HBox>

        <!-- Faixa de feedback transitório (sucesso ao criar/editar/excluir). -->
        <Label fx:id="statusLabel" styleClass="status-flash" visible="false" managed="false"/>


        <!-- ============ 1) Seção: ODMs (criado primeiro) ============ -->
        <TitledPane text="1 · ODMS" styleClass="repo-pane" expanded="true" animated="true">
            <VBox styleClass="repo-card" spacing="16">

                <HBox styleClass="card-header" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Comece por aqui: cada ODM agrupa terminais e recebe uma assinatura depois"
                           styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="card-actions" spacing="8" alignment="CENTER_RIGHT">
                        <Button text="ADICIONAR ODM" onAction="#onAddOdm" styleClass="button,primary"/>
                        <Button fx:id="odmEditButton" text="EDITAR" onAction="#onEditOdm" styleClass="button,secondary"/>
                        <Button fx:id="odmDeleteButton" text="EXCLUIR" onAction="#onRemoveOdm" styleClass="button,danger"/>
                    </HBox>
                </HBox>

                <TextField fx:id="odmSearchField" promptText="Buscar ODM ou assinatura"
                           styleClass="search-field"/>

                <TableView fx:id="odmTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="odmNameColumn" text="Nome" prefWidth="240"/>
                        <TableColumn fx:id="odmSignatureColumn" text="Assinatura vinculada" prefWidth="240"/>
                        <TableColumn fx:id="odmActionColumn" text="Ação" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
        </TitledPane>

        <!-- ============ 2) Seção: Terminais da ODM ============ -->
        <TitledPane text="2 · TERMINAIS" styleClass="repo-pane" expanded="false" animated="true">
            <VBox styleClass="repo-card" spacing="16">

                <HBox styleClass="card-header" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Cadastre os modelos de terminal escolhendo a ODM à qual pertencem"
                           styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="card-actions" spacing="8" alignment="CENTER_RIGHT">
                        <Button fx:id="terminalAddButton" text="ADICIONAR" onAction="#onAddTerminal" styleClass="button,primary"/>
                        <Button fx:id="terminalEditButton" text="EDITAR" onAction="#onEditTerminal" styleClass="button,secondary"/>
                        <Button fx:id="terminalDeleteButton" text="EXCLUIR" onAction="#onRemoveTerminal" styleClass="button,danger"/>
                    </HBox>
                </HBox>

                <!-- Dica de dependência: aparece só quando não há nenhuma ODM cadastrada. -->
                <Label fx:id="terminalOdmHint"
                       text="⚠  Cadastre uma ODM na seção 1 antes de adicionar terminais."
                       styleClass="hint-warning" visible="false" managed="false"/>

                <TextField fx:id="terminalSearchField" promptText="Buscar por nome ou tipo"
                           styleClass="search-field"/>

                <TableView fx:id="terminalTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="terminalNameColumn" text="Nome" prefWidth="200"/>
                        <TableColumn fx:id="terminalTypeColumn" text="Tipo" prefWidth="140"/>
                        <TableColumn fx:id="terminalOdmColumn" text="ODM" prefWidth="200"/>
                        <TableColumn fx:id="terminalActionColumn" text="Ação" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
        </TitledPane>

        <!-- ============ 3) Seção: Assinaturas ============ -->
        <TitledPane text="3 · ASSINATURAS" styleClass="repo-pane" expanded="false" animated="true">
            <VBox styleClass="repo-card" spacing="16">

                <HBox styleClass="card-header" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Cadastre a chave e vincule a uma ODM existente."
                           styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="card-actions" spacing="8" alignment="CENTER_RIGHT">
                        <Button text="ADICIONAR ASSINATURA" onAction="#onAddSigningProfile" styleClass="button,primary"/>
                        <Button fx:id="signingEditButton" text="EDITAR" onAction="#onEditSigningProfile" styleClass="button,secondary"/>
                        <Button fx:id="signingDeleteButton" text="EXCLUIR" onAction="#onRemoveSigningProfile" styleClass="button,danger"/>
                    </HBox>
                </HBox>

                <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="signingSearchField" promptText="Buscar assinatura, alias ou tipo"
                               styleClass="search-field" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="signingTypeFilter" styleClass="filter-combo"/>
                </HBox>

                <TableView fx:id="signingTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="signingNameColumn" text="Nome" prefWidth="200"/>
                        <TableColumn fx:id="signingAliasColumn" text="Alias" prefWidth="150"/>
                        <TableColumn fx:id="signingTypeColumn" text="Tipo" prefWidth="110"/>
                        <TableColumn fx:id="signingFileColumn" text="Arquivo" prefWidth="200"/>
                        <TableColumn fx:id="signingActionColumn" text="Ação" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
        </TitledPane>

        <!-- ============ Seção: Perfis de Clientes (alimenta o seletor de origem do APK) ============ -->
        <TitledPane text="4 · PERFIS DE CLIENTES" styleClass="repo-pane" expanded="false" animated="true">
            <VBox styleClass="repo-card" spacing="16">

                <HBox styleClass="card-header" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Clientes e os aplicativos vinculados a cada um (histórico de versões e versão atual)"
                           styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="card-actions" spacing="8" alignment="CENTER_RIGHT">
                        <Button text="ADICIONAR CLIENTE" onAction="#onAddClient" styleClass="button,primary"/>
                        <Button fx:id="clientSetPrincipalButton" text="TORNAR PRINCIPAL" onAction="#onSetPrincipalClientApk" styleClass="button,secondary"/>
                        <Button fx:id="clientEditButton" text="EDITAR" onAction="#onEditClient" styleClass="button,secondary"/>
                        <Button fx:id="clientDeleteButton" text="EXCLUIR" onAction="#onRemoveClient" styleClass="button,danger"/>
                    </HBox>
                </HBox>

                <TextField fx:id="clientSearchField" promptText="Buscar cliente, app ou versão" styleClass="search-field"/>

                <!-- Árvore: cliente → apps vinculados → versões (com selo ATUAL na principal). -->
                <TreeTableView fx:id="clientTree" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TreeTableColumn fx:id="clientTitleColumn" text="Cliente / App / Versão" prefWidth="260"/>
                        <TreeTableColumn fx:id="clientSubtitleColumn" text="Pacote / Arquivo" prefWidth="260"/>
                        <TreeTableColumn fx:id="clientCurrentColumn" text="Atual" prefWidth="80"/>
                        <TreeTableColumn fx:id="clientTypeColumn" text="Tipo" prefWidth="100"/>
                        <TreeTableColumn fx:id="clientStatusColumn" text="Status" prefWidth="100"/>
                        <TreeTableColumn fx:id="clientActionColumn" text="Ação" prefWidth="80"/>
                    </columns>
                </TreeTableView>
            </VBox>
        </TitledPane>

        <!-- ============ Seção: Repositório de APKs (independente) ============ -->
        <TitledPane text="5 · REPOSITÓRIO DE APKS" styleClass="repo-pane" expanded="false" animated="true">
            <VBox styleClass="repo-card" spacing="16">

                <HBox styleClass="card-header" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Selecione um arquivo .apk: nome, pacote e versão são lidos do próprio arquivo"
                           styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox styleClass="card-actions" spacing="8" alignment="CENTER_RIGHT">
                        <Button text="ADICIONAR APK" onAction="#onAddApk" styleClass="button,primary"/>
                        <Button fx:id="apkNewVersionButton" text="NOVA VERSÃO" onAction="#onNewApkVersion" styleClass="button,secondary"/>
                        <Button fx:id="apkSetPrincipalButton" text="TORNAR PRINCIPAL" onAction="#onSetPrincipalApk" styleClass="button,secondary"/>
                        <Button fx:id="apkEditButton" text="EDITAR" onAction="#onEditApk" styleClass="button,secondary"/>
                        <Button fx:id="apkDeleteButton" text="EXCLUIR" onAction="#onRemoveApk" styleClass="button,danger"/>
                    </HBox>
                </HBox>

                <HBox styleClass="toolbar" spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="apkSearchField" promptText="Buscar APK, cliente ou versão"
                               styleClass="search-field" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="apkTypeFilter" styleClass="filter-combo"/>
                </HBox>

                <!-- Árvore: cada app (pacote) é uma linha-pai que expande nas suas versões. -->
                <TreeTableView fx:id="apkTree" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TreeTableColumn fx:id="apkTitleColumn" text="App" prefWidth="220"/>
                        <TreeTableColumn fx:id="apkVersionColumn" text="Versão" prefWidth="100"/>
                        <TreeTableColumn fx:id="apkSubtitleColumn" text="Pacote / Arquivo" prefWidth="260"/>
                        <TreeTableColumn fx:id="apkCurrentColumn" text="Atual" prefWidth="80"/>
                        <TreeTableColumn fx:id="apkClientColumn" text="Cliente" prefWidth="130"/>
                        <TreeTableColumn fx:id="apkTypeColumn" text="Tipo" prefWidth="100"/>
                        <TreeTableColumn fx:id="apkActionColumn" text="Ação" prefWidth="80"/>
                    </columns>
                </TreeTableView>
            </VBox>
        </TitledPane>

    </VBox>
</ScrollPane>
