<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gertec.smartloader.smartdatabase.ui.CatalogViewController"
      styleClass="feature-view" spacing="12">

    <HBox spacing="8">
        <TextField fx:id="packageNameField" promptText="package (ex.: com.gertec.app)" />
        <TextField fx:id="labelField" promptText="label" />
        <TextField fx:id="versionNameField" promptText="versão (ex.: 1.0.0)" />

        <Button text="Adicionar" onAction="#onAdd" />
        <Button text="Remover selecionado" onAction="#onRemove" />
    </HBox>

    <TableView fx:id="apkTable">
        <columns>
            <TableColumn fx:id="packageColumn" text="Package" prefWidth="260" />
            <TableColumn fx:id="labelColumn" text="Label" prefWidth="180" />
            <TableColumn fx:id="versionColumn" text="Versão" prefWidth="100" />
        </columns>
    </TableView>
</VBox>